{
  "_README": "マシン固有の許可とフック。通常はデザイナの claude-workspace (メニュー / CLI) が settings.local.json を自動生成するので手作業は不要。手で作る場合はこのファイルを同じフォルダの settings.local.json にコピーし、<デザイナexeのパス> を実際のパス (例: C:\\\\path\\\\to\\\\Designer.WpfApp.exe)、<デザインプロジェクトのフォルダ> をデザインプロジェクトのフォルダ名 (例: Design) に置き換える。settings.local.json はマシンごとなので配布・共有しない (Claude Code がローカル上書きとして読む)。sql を許可してよいのは、DB 側の designer.settings.json で AllowCliSqlAccess:true のデータソースだけが実行対象になるため (false のデータソースは CLI 側で拒否される)。rename-* / field-catalog / script-catalog / defaults / template-* / ai-refresh は DB 接続なしで完結する。SessionStart と UserPromptSubmit のフックが .claude/refresh-ai-workspace.ps1 を呼び、ai-refresh で temporary/ 配下の生成物一式 (_field_catalog.md / _script_catalog.md / _defaults/ / _specs/ / _samples/) を書き出す (生成物なので gitignore 済み。ai-refresh はデザイナ 1.3.15 以降で、古い exe ではバージョン判定で自動スキップ)。スクリプトは exe と同フォルダの DLL のタイムスタンプ最大値を temporary/_ai_refresh.stamp に記録し、前回と同じなら再生成をスキップ・変化していれば全取得 (全置換 = 削除されたものも消える) する。これでセッション途中に独自フィールド/拡張ライブラリを再ビルドしても、次のプロンプトで自動的に最新化される。exe が未対応・未配置なら失敗してもセッションは続行する。",
  "permissions": {
    "allow": [
      "Bash(\"<デザイナexeのパス>\" designcheck:*)",
      "Bash(\"<デザイナexeのパス>\" sql:*)",
      "Bash(\"<デザイナexeのパス>\" rename-field:*)",
      "Bash(\"<デザイナexeのパス>\" rename-module:*)",
      "Bash(\"<デザイナexeのパス>\" rename-pageframe:*)",
      "Bash(\"<デザイナexeのパス>\" rename-layout:*)",
      "Bash(\"<デザイナexeのパス>\" rename-enum:*)",
      "Bash(\"<デザイナexeのパス>\" rename-enum-member:*)",
      "Bash(\"<デザイナexeのパス>\" rename-batch:*)",
      "Bash(\"<デザイナexeのパス>\" field-catalog:*)",
      "Bash(\"<デザイナexeのパス>\" script-catalog:*)",
      "Bash(\"<デザイナexeのパス>\" defaults:*)",
      "Bash(\"<デザイナexeのパス>\" template-list:*)",
      "Bash(\"<デザイナexeのパス>\" template-extract:*)",
      "Bash(\"<デザイナexeのパス>\" ai-refresh:*)",
      "Bash(\"<デザイナexeのパス>\" claude-workspace:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude/refresh-ai-workspace.ps1\" \"<デザイナexeのパス>\" \"<デザインプロジェクトのフォルダ>\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude/refresh-ai-workspace.ps1\" \"<デザイナexeのパス>\" \"<デザインプロジェクトのフォルダ>\""
          }
        ]
      }
    ]
  }
}
